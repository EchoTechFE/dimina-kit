{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "globalDependencies": [".dimina-rev"],
  "globalEnv": [
    "ESBUILD_BINARY_PATH",
    "DIMINA_NO_OPEN_BROWSER",
    "DIMINA_DEBUG_PORT",
    "NODE_ENV",
    "CI",
    "PLAYWRIGHT_WORKERS",
    "GITHUB_TOKEN",
    "DIMINA_FORCE_BUILD",
    "DIMINA_E2E_TOOLBAR_SENTINEL",
    "DIMINA_HOME",
    "DIMINA_NATIVE_HOST",
    "DIMINA_DEVTOOLS_DATA_DIR",
    "TEST_PARALLEL_INDEX",
    "DIMINA_DEVTOOLS_MAIN_INSPECTOR",
    "DIMINA_PREWARM_DISABLE",
    "DIMINA_PREWARM_POOL_SIZE",
    "DIMINA_DEBUG_TAP",
    "ELECTRON_DISABLE_SECURITY_WARNINGS",
    "WORKBENCH_OUT_DIR",
    "HOT_RELOAD_STRESS",
    "HOT_RELOAD_WEBCONTENTS_SLACK",
    "HOT_RELOAD_MEM_RATIO",
    "HOT_RELOAD_MEM_CEILING_KB"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^build", "^check-types"]
    },
    "test": {
      "dependsOn": ["^build"],
      "cache": true,
      "outputs": ["test-report*.json", "coverage/**"]
    },
    "test:coverage": {
      "dependsOn": ["^build"],
      "cache": true,
      "outputs": ["coverage/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
