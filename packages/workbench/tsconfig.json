{
  "extends": "@dimina-kit/typescript-config/base.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "noUncheckedIndexedAccess": false,
    "noImplicitAny": false,
    "types": ["vite/client"]
  },
  "include": ["src", "vite.config.ts"],
  "exclude": [
    "node_modules",
    "dist",
    "dist-app"
  ]
}
