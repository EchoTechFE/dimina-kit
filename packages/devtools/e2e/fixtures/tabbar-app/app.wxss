page {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  font-size: 28rpx;
  color: #333;
  background-color: #f5f5f5;
}

.page-marker {
  font-size: 40rpx;
  font-weight: 700;
  padding: 40rpx;
  color: #1a1a1a;
}

.btn {
  display: block;
  width: 80%;
  margin: 20rpx auto;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  background: #1890ff;
  color: #fff;
  border-radius: 12rpx;
}
