{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "sourceMap": true,
    "module": "Node16",
    "moduleResolution": "Node16",
    "declaration": true,
    "declarationMap": true,
    "noEmit": false
  },
  "include": ["src/main", "src/types.ts"],
  "exclude": ["node_modules", "**/*.test.ts", "**/*.spec.ts"]
}
