{
  "extends": "@dimina-kit/typescript-config/react-library.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "noUncheckedIndexedAccess": false,
    "noImplicitAny": false,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/renderer/*"],
      "@dimina-kit/compiler/*": ["../compiler/src/*"],
      "@dimina-kit/devkit": ["../devkit/src/index.ts"],
      "@dimina-kit/electron-deck": ["../electron-deck/src/index.ts"],
      "@dimina-kit/electron-deck/*": ["../electron-deck/src/*"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
