.nested-wrapper {
  margin: 12rpx 0 12rpx 16rpx;
  padding-left: 16rpx;
}

.nested-header {
  display: flex;
  align-items: center;
  padding: 12rpx 0;
  gap: 12rpx;
}

.nested-arrow {
  font-size: 20rpx;
  color: #999;
  width: 24rpx;
}

.nested-label {
  font-size: 28rpx;
  font-weight: 500;
  flex: 1;
}

.nested-depth {
  font-size: 22rpx;
  color: #bbb;
  background: #f5f5f5;
  padding: 2rpx 12rpx;
  border-radius: 4rpx;
}

.nested-content {
  padding-left: 8rpx;
}

.nested-info {
  font-size: 24rpx;
  color: #888;
  padding: 4rpx 0 8rpx 36rpx;
}

.nested-leaf {
  padding: 8rpx 0 8rpx 36rpx;
}

.nested-truncated {
  font-size: 24rpx;
  color: #ccc;
  font-style: italic;
}
