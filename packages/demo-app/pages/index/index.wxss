.menu-item {
  display: flex;
  align-items: center;
  padding: 10rpx 0;
}

.menu-icon {
  font-size: 48rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.menu-content {
  flex: 1;
}

.menu-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 6rpx;
}

.menu-subtitle {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 10rpx;
}

.menu-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.menu-arrow {
  font-size: 32rpx;
  color: #ccc;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 28rpx;
  color: #666;
}

.info-value {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}
