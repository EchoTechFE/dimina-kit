.fullscreen-page {
  min-height: 100vh;
  background: #f5f5f5;
}

.custom-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.nav-content {
  display: flex;
  align-items: center;
  height: 88rpx;
  padding: 0 20rpx;
}

.nav-back {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-back-icon {
  font-size: 36rpx;
  color: #fff;
  font-weight: bold;
}

.nav-title {
  flex: 1;
  text-align: center;
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
  margin-right: 64rpx;
}

.content {
  padding: 30rpx;
}

.desc {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}
