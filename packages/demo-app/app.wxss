/* Global styles for DevTools Feature Demo */

page {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', sans-serif;
  font-size: 28rpx;
  color: #333;
  background-color: #f5f5f5;
  line-height: 1.5;
}

.container {
  padding: 30rpx;
}

.page-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #1a1a1a;
  margin-bottom: 10rpx;
}

.page-desc {
  font-size: 26rpx;
  color: #888;
  margin-bottom: 40rpx;
}

.section {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #eee;
}

.btn {
  display: block;
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  border-radius: 12rpx;
  font-size: 28rpx;
  margin-bottom: 16rpx;
  border: none;
}

.btn::after {
  border: none;
}

.btn-primary {
  background: #4A90D9;
  color: #fff;
}

.btn-success {
  background: #52c41a;
  color: #fff;
}

.btn-warning {
  background: #faad14;
  color: #fff;
}

.btn-danger {
  background: #ff4d4f;
  color: #fff;
}

.btn-info {
  background: #1890ff;
  color: #fff;
}

.btn-default {
  background: #f0f0f0;
  color: #333;
}

.input-field {
  width: 100%;
  height: 72rpx;
  border: 2rpx solid #d9d9d9;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  margin-bottom: 16rpx;
}

.input-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.input-row .input-field {
  flex: 1;
  margin-bottom: 0;
}

.input-row .btn {
  width: 180rpx;
  flex-shrink: 0;
  margin-bottom: 0;
}

.result-area {
  background: #f9f9f9;
  border-radius: 8rpx;
  padding: 20rpx;
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #666;
  word-break: break-all;
  white-space: pre-wrap;
  max-height: 400rpx;
  overflow-y: auto;
}

.tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 6rpx;
  font-size: 22rpx;
  margin-right: 8rpx;
}

.tag-blue {
  background: #e6f7ff;
  color: #1890ff;
}

.tag-green {
  background: #f6ffed;
  color: #52c41a;
}

.tag-red {
  background: #fff2f0;
  color: #ff4d4f;
}

.divider {
  height: 1rpx;
  background: #eee;
  margin: 24rpx 0;
}
